# ==========================================================================
# trading-systems-litreview — .gitignore
# ==========================================================================

# --- Generated pipeline artefacts (regenerated on every run) ---------------
/results/
/data/interim/
/data/processed/
/data/raw/search_results_unzipped/

# --- LaTeX / knitr build side-files ----------------------------------------
*.tex
*.log
*.aux
*.out
*.toc
*.synctex.gz
# but keep our docs/ markdown sources
!docs/**/*.md

# --- R / RStudio -----------------------------------------------------------
.Rhistory
.Rapp.history
.RData
.Ruserdata
.Rproj.user/
*.Rproj
*-Ex.R

# --- Knitr / R Markdown caches ---------------------------------------------
*_cache/
*_files/
/cache/

# --- OS / editor junk ------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*~
*.swp
*.swo
.vscode/
.idea/

# --- Python venv (in case anyone adds analysis scripts) --------------------
__pycache__/
*.py[cod]
.venv/
venv/
