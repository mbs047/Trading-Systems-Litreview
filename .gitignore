# ==========================================================================
# trading-systems-litreview — .gitignore
# ==========================================================================

# --- Generated pipeline artefacts (regenerated on every run) ---------------
# Use /results/* (not /results/) so we can re-include specific files below.
/results/*
/data/interim/
/data/processed/
/data/raw/search_results_unzipped/

# --- ...except the PRISMA flow, which is a committed deliverable ----------
!/results/figures/
/results/figures/*
!/results/figures/prisma_flow.png
!/results/figures/prisma_flow.svg

# --- LaTeX / knitr build side-files ----------------------------------------
*.tex
*.log
*.aux
*.out
*.toc
*.synctex.gz
# but keep our docs/ markdown sources
!docs/**/*.md

# --- R / RStudio -----------------------------------------------------------
.Rhistory
.Rapp.history
.RData
.Ruserdata
.Rproj.user/
*.Rproj
*-Ex.R

# --- renv -----------------------------------------------------------------
# Track only the lockfile + activate.R; ignore the per-machine library
# and the settings file that renv writes locally.
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/staging/
renv/settings.json
renv/settings.dcf

# --- Knitr / R Markdown caches ---------------------------------------------
*_cache/
*_files/
/cache/

# --- OS / editor junk ------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*~
*.swp
*.swo
.vscode/
.idea/

# --- Python venv (in case anyone adds analysis scripts) --------------------
__pycache__/
*.py[cod]
.venv/
venv/
